{% extends 'base.html.twig' %}

{% block title %}Courses - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-book"></i> Courses</h1>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Credits</th>
                        <th>Department</th>
                    </tr>
                </thead>
                <tbody>
                    {% for course in courses %}
                    <tr>
                        <td><span class="badge bg-secondary">{{ course.id }}</span></td>
                        <td><strong>{{ course.code }}</strong></td>
                        <td>
                            <a href="{{ path('course_show', {id: course.id}) }}" class="text-decoration-none">
                                {{ course.name }}
                            </a>
                        </td>
                        <td>{{ course.credits }}</td>
                        <td>
                            {% if course.department %}
                                <span class="badge bg-success">{{ course.department.name }}</span>
                            {% else %}
                                <span class="text-muted">N/A</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted">No courses found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}