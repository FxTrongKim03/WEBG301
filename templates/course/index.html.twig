{% extends 'base.html.twig' %}

{% block title %}Courses - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-book"></i> Courses</h1>
    {% if app.user %}
        <a href="{{ path('course_new') }}" class="btn btn-add-warning">
            <i class="bi bi-plus-circle"></i> Add Course
        </a>
    {% endif %}
</div>

<div class="custom-card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle data-table">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Credits</th>
                        <th>Department</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for course in courses %}
                    <tr>
                        <td><span class="module-badge module-badge-primary">{{ course.id }}</span></td>
                        <td><strong>{{ course.code }}</strong></td>
                        <td>
                            <a href="{{ path('course_show', {id: course.id}) }}" class="text-decoration-none">
                                {{ course.name }}
                            </a>
                        </td>
                        <td>{{ course.credits }}</td>
                        <td>
                            {% if course.department %}
                                <span class="module-badge module-badge-info">{{ course.department.name }}</span>
                            {% else %}
                                <span class="text-muted">N/A</span>
                            {% endif %}
                        </td>
                        <td>
                                <div class="action-buttons">
                                    <a href="{{ path('course_show', {id: course.id}) }}" class="btn btn-sm btn-view" title="View course" data-bs-toggle="tooltip" aria-label="View course">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if app.user %}
                                        <a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-sm btn-edit" title="Edit course" data-bs-toggle="tooltip" aria-label="Edit course">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" action="{{ path('course_delete', {id: course.id}) }}" onsubmit="return confirm('Are you sure you want to delete this course?');" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                                            <button type="submit" class="btn btn-sm btn-delete" title="Delete course" data-bs-toggle="tooltip" aria-label="Delete course">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted">No courses found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}