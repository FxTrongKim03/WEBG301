{% extends 'base.html.twig' %}

{% block title %}Courses - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-book"></i> Courses</h1>
    {% if app.user %}
        <a href="{{ path('course_new') }}" class="btn btn-warning">
            <i class="bi bi-plus-circle"></i> Add Course
        </a>
    {% endif %}
</div>

{# Search & Filter Bar #}
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search by course name or code..." value="{{ search|default('') }}">
                    {% if search %}
                        <a href="{{ path('course_index') }}" class="btn btn-outline-secondary">Clear</a>
                    {% endif %}
                </div>
            </div>
            <div class="col-md-6">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Credits</th>
                        <th>Department</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for course in courses %}
                    <tr>
                        <td data-label="ID"><span class="badge bg-secondary">{{ course.id }}</span></td>
                        <td data-label="Code"><strong>{{ course.code }}</strong></td>
                        <td data-label="Name">
                            <a href="{{ path('course_show', {id: course.id}) }}" class="text-decoration-none">
                                {{ course.name }}
                            </a>
                        </td>
                        <td data-label="Credits">{{ course.credits }}</td>
                        <td data-label="Department">
                            {% if course.department %}
                                <span class="badge bg-success">{{ course.department.name }}</span>
                            {% else %}
                                <span class="text-muted">N/A</span>
                            {% endif %}
                        </td>
                        <td data-label="Actions">
                                <div class="btn-group d-inline-flex d-lg-inline-flex" role="group">
                                    <a href="{{ path('course_show', {id: course.id}) }}" class="btn btn-sm btn-primary" title="View course" data-bs-toggle="tooltip" aria-label="View course">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if app.user %}
                                        <a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-sm btn-warning" title="Edit course" data-bs-toggle="tooltip" aria-label="Edit course">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" action="{{ path('course_delete', {id: course.id}) }}" onsubmit="return confirm('Are you sure you want to delete this course?');" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                                            <button type="submit" class="btn btn-sm btn-danger" title="Delete course" data-bs-toggle="tooltip" aria-label="Delete course">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted">No courses found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}