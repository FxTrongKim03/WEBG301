{% extends 'base.html.twig' %}

{% block title %}{{ course.name }} - Student Management System{% endblock %}

{% block body %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ path('course_index') }}">Courses</a></li>
        <li class="breadcrumb-item active">{{ course.name }}</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        <i class="bi bi-book"></i> {{ course.name }}
        <span class="badge bg-warning text-dark">{{ course.code }}</span>
    </h1>
    <div>
        <a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash"></i> Delete
        </button>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Course Information</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <td class="text-muted" style="width: 35%;"><strong>Course ID:</strong></td>
                        <td><span class="badge bg-secondary">{{ course.id }}</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Name:</strong></td>
                        <td>{{ course.name }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Code:</strong></td>
                        <td>{{ course.code }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Credits:</strong></td>
                        <td>{{ course.credits }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted"><strong>Department:</strong></td>
                        <td>
                            {% if course.department %}
                                <a href="{{ path('department_show', {id: course.department.id}) }}" class="text-decoration-none">
                                    {{ course.department.name }}
                                </a>
                            {% else %}
                                <span class="text-muted">No department assigned</span>
                            {% endif %}
                        </td>
                    </tr>
                </table>
                <hr>
                <h6 class="text-muted">Description:</h6>
                <p class="mb-0">{{ course.description|default('No description provided.') }}</p>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Enrolled Students ({{ course.enrollments|length }})</h5>
            </div>
            <div class="card-body">
                {% if course.enrollments is empty %}
                    <p class="text-muted">No students are currently enrolled in this course.</p>
                {% else %}
                    <div class="list-group">
                        {% for enrollment in course.enrollments %}
                            <a href="{{ path('student_show', {id: enrollment.student.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>{{ enrollment.student.firstName }} {{ enrollment.student.lastName }}</strong>
                                    <br>
                                    <small class="text-muted"><i class="bi bi-envelope"></i> {{ enrollment.student.email }}</small>
                                </div>
                                <div class="text-end">
                                    {% if enrollment.status == 'active' %}
                                        <span class="badge bg-primary">Active</span>
                                    {% elseif enrollment.status == 'completed' %}
                                        <span class="badge bg-success">Completed</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ enrollment.status }}</span>
                                    {% endif %}
                                    <br>
                                    {% if enrollment.grade %}
                                        <small class="text-muted">Grade: {{ enrollment.grade }}</small>
                                    {% endif %}
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the course <strong>{{ course.name }}</strong>?</p>
                <p class="text-danger">
                    <i class="bi bi-exclamation-triangle"></i> 
                    This action cannot be undone. All enrollments related to this course will also be deleted!
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                {# Form gọi phương thức Delete trong CourseController #}
                <form method="post" action="{{ path('course_delete', {id: course.id}) }}" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete Course
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}