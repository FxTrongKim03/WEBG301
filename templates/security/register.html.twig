{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <div class="card p-4">
      <h3 class="mb-3">Create account</h3>

      {% if registrationForm.vars.errors|length > 0 %}
        <div class="alert alert-danger">{{ form_errors(registrationForm) }}</div>
      {% endif %}

      {{ form_start(registrationForm) }}

        <div class="mb-3">
          <label for="registerEmail" class="form-label">Email</label>
          {{ form_widget(registrationForm.email, { 'attr': {'class': 'form-control', 'id': 'registerEmail', 'placeholder': 'you@example.com'} }) }}
          {{ form_errors(registrationForm.email) }}
        </div>

        <div class="mb-3">
          <label for="registerPassword" class="form-label">Password</label>
          {{ form_widget(registrationForm.plainPassword.first, { 'attr': {'class': 'form-control', 'id': 'registerPassword'} }) }}
          {{ form_errors(registrationForm.plainPassword.first) }}
        </div>

        <div class="mb-3">
          <label for="registerPasswordConfirm" class="form-label">Confirm Password</label>
          {{ form_widget(registrationForm.plainPassword.second, { 'attr': {'class': 'form-control', 'id': 'registerPasswordConfirm'} }) }}
          {{ form_errors(registrationForm.plainPassword.second) }}
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-person-plus me-2"></i> Register
          </button>
        </div>

      {{ form_end(registrationForm) }}

      <div class="text-center mt-3">
        <small>Already have an account? <a href="{{ path('app_login') }}">Sign in</a></small>
      </div>
    </div>
  </div>
</div>
{% endblock %}
