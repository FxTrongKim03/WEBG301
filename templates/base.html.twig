<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Student Management System{% endblock %}</title>
    <meta name="csrf-token" content="{{ csrf_token('api') }}">
    
    {# Bootstrap 5 CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {# Bootstrap 5 CSS - non-blocking preload #}
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"></noscript>

    {# Bootstrap Icons - non-blocking preload #}
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"></noscript>

    {# Google Font: Inter #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    {# Critical inline CSS (minimal above-the-fold) #}
    <style id="critical-css">
        html,body{height:100%}
        body{background:#f4f6fb;font-family:Inter,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial;margin:0;color:#0f172a;-webkit-font-smoothing:antialiased}
        .navbar{background:#fff;border-bottom:1px solid rgba(16,24,40,0.04)}
        .navbar-brand{font-weight:700;font-size:1.4rem;color:#2563eb}
        .container-lg{padding-top:1.5rem;padding-bottom:1.5rem}
        .card{border-radius:12px;background:#fff}
        .btn{border-radius:6px}
        a{text-decoration:none;color:#2563eb}
        footer{border-top:1px solid #e9ecef}
    </style>

    {# Custom CSS #}
    {% block stylesheets %}
        <link rel="preload" href="{{ asset('styles/app.min.css') }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link rel="stylesheet" href="{{ asset('styles/app.min.css') }}"></noscript>
    {% endblock %}
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path('home') }}">
                <i class="bi bi-mortarboard-fill"></i> Student Management
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('home') }}">
                            <i class="bi bi-house-door"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('student_index') }}">
                            <i class="bi bi-people"></i> Students
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('department_index') }}">
                            <i class="bi bi-building"></i> Departments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('course_index') }}">
                            <i class="bi bi-book"></i> Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('enrollment_index') }}">
                            <i class="bi bi-journal-check"></i> Enrollments
                        </a>
                    </li>

                    {# Authentication links #}
                    {% if app.user %}
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="bi bi-person-circle"></i> {{ app.user.email }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <form action="{{ path('app_logout') }}" method="post" class="d-inline">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                <button type="submit" class="btn btn-link nav-link">Logout</button>
                            </form>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_register') }}">
                                <i class="bi bi-person-plus"></i> Register
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_login') }}">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </li>
                    {% endif %}

                </ul>
            </div>
        </div>
    </nav>

    {# Flash Messages rendered as Bootstrap toasts (non-blocking) #}
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer" style="z-index: 1080;">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                {% set visual = type == 'error' ? 'danger' : (type == 'success' ? 'success' : 'info') %}
                <div class="toast align-items-center text-bg-{{ visual }} border-0 mb-2" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            {{ message|raw }}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# Main Content #}
    <main class="container-lg my-5">
        {% block body %}{% endblock %}
    </main>

    {# Footer #}
    <footer class="bg-light text-center text-muted py-4 mt-5">
        <div class="container">
            <p class="mb-0">
                &copy; {{ 'now'|date('Y') }} Student Management System | 
                <a href="{{ path('home_about') }}" class="text-decoration-none">About</a>
            </p>
        </div>
    </footer>

    {# Bootstrap JS Bundle (includes Popper) - defer to avoid blocking render #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
    
    {# Custom JavaScript #}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
    <script>
        // Auto-show all toasts rendered server-side and initialize UI helpers
        document.addEventListener('DOMContentLoaded', function() {
            var toastElList = [].slice.call(document.querySelectorAll('.toast'));
            toastElList.forEach(function(toastEl) {
                var toast = new bootstrap.Toast(toastEl, { delay: 6000 });
                toast.show();
            });

            // Initialize Bootstrap tooltips for action buttons
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) { new bootstrap.Tooltip(el); });

            // Add show/hide password toggle for password inputs
            document.querySelectorAll('input[type="password"]').forEach(function(pw) {
                try {
                    if (pw.dataset.pwToggleAdded) return;
                    pw.dataset.pwToggleAdded = '1';

                    var parent = pw.parentElement;
                    // If the input is inside a Bootstrap form-floating, append an absolute-positioned toggle
                    if (parent && parent.classList && parent.classList.contains('form-floating')) {
                        parent.classList.add('position-relative');
                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'btn btn-sm btn-outline-secondary position-absolute top-50 end-0 translate-middle-y me-2';
                        btn.setAttribute('aria-label', 'Toggle password visibility');
                        btn.innerHTML = '<i class="bi bi-eye"></i>';
                        btn.addEventListener('click', function() {
                            if (pw.type === 'password') {
                                pw.type = 'text';
                                btn.innerHTML = '<i class="bi bi-eye-slash"></i>';
                            } else {
                                pw.type = 'password';
                                btn.innerHTML = '<i class="bi bi-eye"></i>';
                            }
                        });
                        parent.appendChild(btn);
                    } else {
                        // Fallback: wrap input in an input-group and add the toggle
                        var group = document.createElement('div');
                        group.className = 'input-group';
                        parent.insertBefore(group, pw);
                        group.appendChild(pw);

                        var btn = document.createElement('button');
                        btn.type = 'button';
                        btn.className = 'btn btn-outline-secondary';
                        btn.setAttribute('aria-label', 'Toggle password visibility');
                        btn.innerHTML = '<i class="bi bi-eye"></i>';
                        btn.addEventListener('click', function() {
                            if (pw.type === 'password') {
                                pw.type = 'text';
                                btn.innerHTML = '<i class="bi bi-eye-slash"></i>';
                            } else {
                                pw.type = 'password';
                                btn.innerHTML = '<i class="bi bi-eye"></i>';
                            }
                        });

                        var append = document.createElement('span');
                        append.className = 'input-group-text p-0';
                        append.appendChild(btn);
                        group.appendChild(append);
                    }
                } catch (e) {
                    // ignore DOM manipulation errors
                    console.error('pw toggle error', e);
                }
            });
        });
    </script>
</body>
</html>