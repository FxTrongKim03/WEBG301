{% extends 'base.html.twig' %}

{% block title %}Enrollments - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-journal-check"></i> Enrollments</h1>
    <a href="{{ path('enrollment_new') }}" class="btn btn-info">
        <i class="bi bi-plus-circle"></i> Add Enrollment
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                            <th>ID</th>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Status</th>
                            <th>Grade</th>
                            <th>Actions</th>
                        </tr>
                </thead>
                <tbody>
                    {% for enrollment in enrollments %}
                    <tr>
                        <td><span class="badge bg-secondary">{{ enrollment.id }}</span></td>
                        <td>{{ enrollment.student.firstName }} {{ enrollment.student.lastName }}</td>
                        <td>{{ enrollment.course.name }}</td>
                        <td>
                            {% if enrollment.status == 'active' %}
                                <span class="badge bg-primary">Active</span>
                            {% elseif enrollment.status == 'completed' %}
                                <span class="badge bg-success">Completed</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ enrollment.status }}</span>
                            {% endif %}
                        </td>
                        <td>{{ enrollment.grade|default('N/A') }}</td>
                        <td>
                            <div class="btn-group d-none d-md-inline-flex" role="group">
                                <a href="{{ path('enrollment_show', {id: enrollment.id}) }}" class="btn btn-sm btn-outline-primary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('enrollment_edit', {id: enrollment.id}) }}" class="btn btn-sm btn-outline-warning" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('enrollment_delete', {id: enrollment.id}) }}" onsubmit="return confirm('Are you sure you want to delete this enrollment?');" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ enrollment.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted">No enrollments found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}