{% extends 'base.html.twig' %}

{% block title %}Enrollments - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-journal-check"></i> Enrollments</h1>
    {% if app.user %}
        <a href="{{ path('enrollment_new') }}" class="btn btn-info">
            <i class="bi bi-plus-circle"></i> Add Enrollment
        </a>
    {% endif %}
</div>

{# Search & Filter Bar #}
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search by student or course..." value="{{ search|default('') }}">
                    {% if search %}
                        <a href="{{ path('enrollment_index') }}" class="btn btn-outline-secondary">Clear</a>
                    {% endif %}
                </div>
            </div>
            <div class="col-md-6">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                            <th>ID</th>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Status</th>
                            <th>Grade</th>
                            <th>Actions</th>
                        </tr>
                </thead>
                <tbody>
                    {% for enrollment in enrollments %}
                    <tr>
                        <td data-label="ID"><span class="badge bg-secondary">{{ enrollment.id }}</span></td>
                        <td data-label="Student">{{ enrollment.student.firstName }} {{ enrollment.student.lastName }}</td>
                        <td data-label="Course">{{ enrollment.course.name }}</td>
                        <td data-label="Status">
                            {% if enrollment.status == 'active' %}
                                <span class="badge bg-primary">Active</span>
                            {% elseif enrollment.status == 'completed' %}
                                <span class="badge bg-success">Completed</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ enrollment.status }}</span>
                            {% endif %}
                        </td>
                        <td data-label="Grade">{{ enrollment.grade|default('N/A') }}</td>
                        <td data-label="Actions">
                            <div class="btn-group d-inline-flex d-lg-inline-flex" role="group">
                                <a href="{{ path('enrollment_show', {id: enrollment.id}) }}" class="btn btn-sm btn-primary" title="View enrollment" data-bs-toggle="tooltip" aria-label="View enrollment">
                                    <i class="bi bi-eye"></i>
                                </a>
                                {% if app.user %}
                                    <a href="{{ path('enrollment_edit', {id: enrollment.id}) }}" class="btn btn-sm btn-warning" title="Edit enrollment" data-bs-toggle="tooltip" aria-label="Edit enrollment">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('enrollment_delete', {id: enrollment.id}) }}" onsubmit="return confirm('Are you sure you want to delete this enrollment?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ enrollment.id) }}">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete enrollment" data-bs-toggle="tooltip" aria-label="Delete enrollment">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted">No enrollments found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}