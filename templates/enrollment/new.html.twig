{% extends 'base.html.twig' %}

{% block title %}Create New Enrollment - Student Management System{% endblock %}

{% block body %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ path('enrollment_index') }}">Enrollments</a></li>
        <li class="breadcrumb-item active">New Enrollment</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0">
                    <i class="bi bi-journal-check"></i> Create New Enrollment
                </h4>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                
                <div class="mb-3">
                    {{ form_label(form.student) }}
                    {{ form_widget(form.student) }}
                    {{ form_errors(form.student) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.course) }}
                    {{ form_widget(form.course) }}
                    {{ form_errors(form.course) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.status) }}
                        {{ form_widget(form.status) }}
                        {{ form_errors(form.status) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.grade) }}
                        {{ form_widget(form.grade) }}
                        {{ form_errors(form.grade) }}
                        <small class="text-muted">Leave blank if not yet graded</small>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="{{ path('enrollment_index') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-info">
                        <i class="bi bi-check-circle"></i> Create Enrollment
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}