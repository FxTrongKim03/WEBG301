{% extends 'base.html.twig' %}

{% block title %}Edit Enrollment - Student Management System{% endblock %}

{% block body %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ path('enrollment_index') }}">Enrollments</a></li>
        <li class="breadcrumb-item"><a href="{{ path('enrollment_show', {id: enrollment.id}) }}">Enrollment #{{ enrollment.id }}</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="custom-card">
            <div class="card-header card-header-info">
                <h4 class="mb-0">
                    <i class="bi bi-pencil"></i> Edit Enrollment
                </h4>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <strong>Student:</strong> {{ enrollment.student.firstName }} {{ enrollment.student.lastName }}<br>
                    <strong>Course:</strong> {{ enrollment.course.name }} ({{ enrollment.course.code }})
                </div>

                {{ form_start(form) }}

                {# Hide student and course fields since they can't be changed #}
                <div style="display: none;">
                    {{ form_widget(form.student) }}
                    {{ form_widget(form.course) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.status) }}
                        {{ form_widget(form.status) }}
                        {{ form_errors(form.status) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.grade) }}
                        {{ form_widget(form.grade) }}
                        {{ form_errors(form.grade) }}
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="{{ path('enrollment_show', {id: enrollment.id}) }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-add-info">
                        <i class="bi bi-check-circle"></i> Update Enrollment
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}