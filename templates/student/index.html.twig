{% extends 'base.html.twig' %}

{% block title %}All Students - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people-fill"></i> Students</h1>
    <div>
        {% if app.user %}
            <a href="{{ path('student_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Student
            </a>
        {% endif %}
    </div>
</div>

{# Search & Filter Bar #}
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="GET" class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search by name or email..." value="{{ search }}">
                    {% if search %}
                        <a href="{{ path('student_index') }}" class="btn btn-outline-secondary">Clear</a>
                    {% endif %}
                </div>
            </div>
            <div class="col-md-6">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

{% if students is empty %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No students found. 
        <a href="{{ path('student_new') }}" class="alert-link">Create the first student</a>.
    </div>
{% else %}
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Date of Birth</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for student in students %}
                        <tr>
                            <td data-label="ID"><span class="badge bg-secondary">{{ student.id }}</span></td>
                            <td data-label="Name">
                                <strong>{{ student.firstName }} {{ student.lastName }}</strong>
                            </td>
                            <td data-label="Email">
                                <a href="mailto:{{ student.email }}" class="text-decoration-none">
                                    <i class="bi bi-envelope"></i> {{ student.email }}
                                </a>
                            </td>
                            <td data-label="Department">
                                {% if student.department %}
                                    <span class="badge bg-info">
                                        {{ student.department.code }}
                                    </span>
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                            <td data-label="Date of Birth">
                                {% if student.dateOfBirth %}
                                    {{ student.dateOfBirth|date('Y-m-d') }}
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                            <td data-label="Actions">
                                <div class="btn-group d-inline-flex d-lg-inline-flex" role="group">
                                                <a href="{{ path('student_show', {id: student.id}) }}"
                                                    class="btn btn-sm btn-primary" title="View student" data-bs-toggle="tooltip" aria-label="View student">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    {% if app.user %}
                                                     <a href="{{ path('student_edit', {id: student.id}) }}"
                                                         class="btn btn-sm btn-warning" title="Edit student" data-bs-toggle="tooltip" aria-label="Edit student">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Pagination placeholder (you can implement this later) #}
    <div class="text-muted text-center mt-3">
        <small>Showing {{ students|length }} students</small>
    </div>
{% endif %}

{# No API UI: DOM updates handled only for AJAX forms where appropriate #}
{% endblock %}