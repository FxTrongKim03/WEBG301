{% extends 'base.html.twig' %}

{% block title %}All Students - Student Management System{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people-fill"></i> Students</h1>
    <a href="{{ path('student_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Student
    </a>
</div>

{% if students is empty %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No students found. 
        <a href="{{ path('student_new') }}" class="alert-link">Create the first student</a>.
    </div>
{% else %}
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Date of Birth</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for student in students %}
                        <tr>
                            <td><span class="badge bg-secondary">{{ student.id }}</span></td>
                            <td>
                                <strong>{{ student.firstName }} {{ student.lastName }}</strong>
                            </td>
                            <td>
                                <a href="mailto:{{ student.email }}" class="text-decoration-none">
                                    <i class="bi bi-envelope"></i> {{ student.email }}
                                </a>
                            </td>
                            <td>
                                {% if student.department %}
                                    <span class="badge bg-info">
                                        {{ student.department.code }}
                                    </span>
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if student.dateOfBirth %}
                                    {{ student.dateOfBirth|date('Y-m-d') }}
                                {% else %}
                                    <span class="text-muted">N/A</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a href="{{ path('student_show', {id: student.id}) }}" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('student_edit', {id: student.id}) }}" 
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Pagination placeholder (you can implement this later) #}
    <div class="text-muted text-center mt-3">
        <small>Showing {{ students|length }} students</small>
    </div>
{% endif %}
{% endblock %}